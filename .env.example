# ─────────────────────────────────────────────────────────────────────────────
# AI Resume Analyzer — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Sentence-Transformers model ───────────────────────────────────────────────
# HuggingFace model name used for semantic similarity scoring.
# Swap for a larger model (e.g. all-mpnet-base-v2) for higher accuracy.
ST_MODEL_NAME=all-MiniLM-L6-v2

# ── CLI default file paths ────────────────────────────────────────────────────
# Used by resume_analyzer.py when no command-line arguments are provided.
DEFAULT_RESUME_PATH=sample_resume.txt
DEFAULT_JD_PATH=job_description.txt

# ── HuggingFace cache (optional) ─────────────────────────────────────────────
# Override where sentence-transformers stores downloaded models.
# Defaults to ~/.cache/huggingface if not set.
# HF_HOME=/path/to/your/model/cache

# ── Streamlit server (optional) ──────────────────────────────────────────────
# Uncomment and adjust if you need a non-default port.
# STREAMLIT_SERVER_PORT=8501
# STREAMLIT_SERVER_ADDRESS=0.0.0.0
