[flake8]
# Maximum line length — generous to avoid fighting Streamlit's verbose HTML strings
max-line-length = 120

# Ignored rules:
#   E501  line too long (covered by max-line-length above)
#   W503  line break before binary operator (conflicts with Black)
#   E302  expected 2 blank lines (relaxed for script-style files)
extend-ignore = W503, E302

# Files and directories to skip
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    env,
    .cache,
    *.egg-info,
    build,
    dist

# Only lint these source files — exclude auto-generated or config files
per-file-ignores =
    # Test file: allow long lines for mock strings & docstrings
    test_resume_analyzer.py: E501
